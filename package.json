{
 "name": "codex-web-console",
 "private": false,
 "version": "1.0.2",
 "type": "module",
 "repository": {
  "type": "git",
  "url": "git+https://github.com/lycohana/codex-web-console.git"
 },
 "homepage": "https://github.com/lycohana/codex-web-console#readme",
 "bugs": {
  "url": "https://github.com/lycohana/codex-web-console/issues"
 },
 "bin": {
  "codex-web-console": "bin/codex-web-console.js"
 },
 "engines": {
  "node": ">=20",
  "bun": ">=1.2"
 },
 "scripts": {
  "start": "vite dev --host 127.0.0.1 --open",
  "dev": "vite dev --host 127.0.0.1",
  "build": "vite build",
  "preview": "vite preview --host 127.0.0.1",
  "prepack": "bun run build",
  "prepare": "svelte-kit sync || echo ''",
  "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
  "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
  "test": "bun test",
  "release": "semantic-release"
 },
 "devDependencies": {
  "@semantic-release/changelog": "^6.0.3",
  "@semantic-release/commit-analyzer": "^13.0.1",
  "@semantic-release/git": "^10.0.1",
  "@semantic-release/github": "^12.0.6",
  "@semantic-release/npm": "^13.1.5",
  "@semantic-release/release-notes-generator": "^14.1.0",
  "@sveltejs/kit": "^2.57.0",
  "@sveltejs/vite-plugin-svelte": "^7.0.0",
  "@types/node": "^25.6.0",
  "@types/sanitize-html": "^2.16.1",
  "conventional-changelog-conventionalcommits": "^9.3.1",
  "semantic-release": "^25.0.3",
  "svelte": "^5.55.2",
  "svelte-adapter-bun": "^1.0.1",
  "svelte-check": "^4.4.6",
  "typescript": "^6.0.2",
  "vite": "^8.0.7"
 },
 "dependencies": {
  "marked": "^18.0.2",
  "sanitize-html": "^2.17.3"
 }
}
